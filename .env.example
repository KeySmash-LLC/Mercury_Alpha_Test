# API keys used by the pipeline (optional, depends on your setup)
# Copy to .env and fill in your values

# PostHog analytics — required to run the pipeline.
# A unique ID is generated automatically the first time you run setup-chrome-profile.sh
# or on your first pipeline run. Do not share this value with others.
POSTHOG_DISTINCT_ID=

# PostHog API key (provided by the project maintainer)
POSTHOG_API_KEY=

# Optional name field to help us with analytics
# Put your name here (if you want)
POSTHOG_USER_NAME=

# DeepSeek API key (if using DeepSeek for build agents)
DEEP_SEEK_API_KEY=

# Google API key (if using Gemini for embeddings)
GOOGLE_API_KEY=

# Disable telemetry
ANONYMIZED_TELEMETRY=false
