# ATS Platform Credentials — CUSTOMIZE THIS (DO NOT COMMIT the real version)
# Copy to credentials.yaml and fill in your actual credentials.
# The submit agent uses these when a platform session has expired.

workday:
  username: "your.email@example.com"
  password: "your-workday-password"
  note: "One Workday account works across most companies using Workday ATS"

